# ══════════════════════════════════════════════════════════════════════════════
# RVCE Placement Portal — Docker Environment Variables
# ══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env before running docker compose:
#   cp .env.docker .env
#   # Edit .env with your actual values
#   docker compose -f docker-compose.prod.yml up -d
# ══════════════════════════════════════════════════════════════════════════════

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
DB_USER=postgres
DB_PASSWORD=testpassword123
DB_NAME=mca_placement

# ── Database (MongoDB) ────────────────────────────────────────────────────────
MONGO_DB_NAME=mca_placement

# ── Authentication ────────────────────────────────────────────────────────────
JWT_SECRET=test-jwt-secret-for-build-verification
JWT_EXPIRES_IN=7d

# ── Google OAuth & Drive (optional — leave blank to disable) ──────────────────
GOOGLE_CLIENT_ID=
GOOGLE_DRIVE_FOLDER_ID=
GOOGLE_SERVICE_ACCOUNT_CLIENT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=

# ── Web Push / VAPID Keys (optional — generate with: npx web-push generate-vapid-keys) ──
WEB_PUSH_PUBLIC_KEY=
WEB_PUSH_PRIVATE_KEY=
WEB_PUSH_SUBJECT=mailto:placements@rvce.edu.in

# ── SPC Configuration ────────────────────────────────────────────────────────
SPC_EMAILS=

# ── URLs ──────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost
BACKEND_URL=http://localhost:4000
